{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/GridPlot",
    "definitions": {
        "GridPlot": {
            "required": [
                "id",
                "size",
                "flags",
                "graphID",
                "name"
            ],
            "properties": {
                "id": {
                    "type": "string"
                },
                "size": {
                    "$ref": "#/definitions/PbApp.Size",
                    "additionalProperties": false
                },
                "flags": {
                    "type": "integer"
                },
                "graphID": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "name": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Grid Plot"
        },
        "PbApp.Size": {
            "required": [
                "w",
                "h"
            ],
            "properties": {
                "w": {
                    "type": "number"
                },
                "h": {
                    "type": "number"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Size"
        }
    }
}