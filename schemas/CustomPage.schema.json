{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$ref": "#/definitions/CustomPage",
    "definitions": {
        "CustomPage": {
            "required": [
                "id",
                "name",
                "size",
                "author",
                "gridCells",
                "gridPlotID"
            ],
            "properties": {
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "size": {
                    "$ref": "#/definitions/PbApp.Size",
                    "additionalProperties": false
                },
                "author": {
                    "type": "string"
                },
                "gridCells": {
                    "items": {
                        "type": "integer"
                    },
                    "type": "array"
                },
                "gridPlotID": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Custom Page"
        },
        "PbApp.Size": {
            "required": [
                "w",
                "h"
            ],
            "properties": {
                "w": {
                    "type": "number"
                },
                "h": {
                    "type": "number"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "title": "Size"
        }
    }
}